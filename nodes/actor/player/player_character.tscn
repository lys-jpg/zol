[sub_resource type="GDScript" id="GDScript_21flv"]
resource_name = "player_dashing_state"
script/source = "extends State

@onready var state_machine: StateMachine = $\"..\"
@onready var machine_owner :CharacterBody2D = state_machine.machine_owner

var walk_speed = 2500
var friction = 20000
var acceleration = 200
var gravity = 1000

func physics_update(delta: float) -> void:
	machine_owner.velocity.y += gravity * delta
	
	if Input.is_action_just_pressed(\"down\"):
		transitioned.emit(\"Crouching\")
	
	var direction = Input.get_axis(\"left\", \"right\")
	if direction:
		machine_owner.velocity.x = move_toward(machine_owner.velocity.x, direction * walk_speed, acceleration * delta)
	else:
		machine_owner.velocity.x = move_toward(machine_owner.velocity.x, 0, friction * delta)
		transitioned.emit(\"Idle\")
	
	machine_owner.move_and_slide()


func _on_dash_timer_timeout() -> void:
	pass # Replace with function body.
"

[sub_resource type="GDScript" id="GDScript_fg4e1"]
resource_name = "attackState"
script/source = "extends State
"

[sub_resource type="GDScript" id="GDScript_bg4de"]
resource_name = "WalkingState"
script/source = "extends State

@onready var state_machine: StateMachine = $\"..\"
@onready var machine_owner :CharacterBody2D = state_machine.machine_owner

var walk_speed = 1500
var run_speed = 2500
var friction = 20000
var acceleration = 200
var gravity = 1000

var is_running = false

func physics_update(delta: float) -> void:
	machine_owner.velocity.y += gravity * delta
	var speed : int
	
	
	if Input.is_action_just_pressed(\"down\"):
		transitioned.emit(\"Crouching\")
	
	
	var direction = Input.get_axis(\"left\", \"right\")
	if direction and machine_owner.dash_timer.time_left < 0.5:
		is_running = true
		machine_owner.dash_timer.stop()
		machine_owner.dash_timer.wait_time = 0.5
		
	if direction:
		if is_running == true:
			speed = run_speed
			print(\"running!\")
		else:
			speed = walk_speed
		machine_owner.velocity.x = move_toward(machine_owner.velocity.x, direction * speed, acceleration * delta)
	else:
		machine_owner.velocity.x = move_toward(machine_owner.velocity.x, 0, friction * delta)
		machine_owner.dash_timer.start()

	
	machine_owner.move_and_slide()


func _on_dash_timer_timeout() -> void:
	transitioned.emit(\"Idle\")
	pass # Replace with function body.
"

[sub_resource type="GDScript" id="GDScript_p4ymi"]
resource_name = "player_crouch_state"
script/source = "extends State

func enter() -> void:
	if not Input.is_action_pressed(\"down\"):
		transitioned.emit(\"Idle\")

func physics_update(delta: float) -> void:
	
	if Input.is_action_just_released(\"down\"):
		transitioned.emit(\"Idle\")
	if Input.is_action_just_pressed(\"attack\"):
		transitioned.emit(\"CrouchAttack\")
"

[sub_resource type="GDScript" id="GDScript_opqj4"]
resource_name = "player_crouch_attack"
script/source = "extends State

func enter() -> void:
	await get_tree().create_timer(0.2).timeout
	transitioned.emit(\"Crouching\")
"

