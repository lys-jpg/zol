[sub_resource type="GDScript" id="GDScript_j556s"]
resource_name = "playerCharacter"
script/source = "extends CharacterBody2D

@export var stats: StatsBase

@onready var state_label: Label = $StateLabel

@onready var actor_sprite: AnimatedSprite2D = $AnimatedSprite2D
@onready var camera: Camera2D = $Camera2D
@onready var coyote_timer := $CoyoteTimer
@onready var dash_timer: Timer = $DashTimer

const SPEED = 90.0
const ACCEL = 500.0
const FRICTION = 300.0
const JUMP_VELOCITY = -300.0


var was_on_floor = false

func attack():
	print(\"Attack pressed!\")

func _physics_process(delta: float) -> void:
	pass
	
"

[sub_resource type="GDScript" id="GDScript_4k7gw"]
resource_name = "IdleState"
script/source = "extends State


@onready var state_machine: StateMachine = $\"..\"
@onready var machine_owner :CharacterBody2D = state_machine.machine_owner

var walk_speed := 300
var jump_speed := 300
var gravity := 1000
var friction := 2000
var acceleration := 3000

func physics_update(delta: float) -> void:
	
	var direction = Input.get_axis(\"left\", \"right\")
	
	if Input.is_action_just_pressed(\"down\"):
		transitioned.emit(\"Crouching\")
	if direction: 
		transitioned.emit(\"Walking\")
	if Input.is_action_just_pressed(\"jump\"):
		transitioned.emit(\"Jumping\")
	if Input.is_action_just_pressed(\"attack\"):
		transitioned.emit(\"Attacking\")
		
	
	machine_owner.velocity.y += gravity * delta
	machine_owner.move_and_slide()
"

[sub_resource type="GDScript" id="GDScript_1y48n"]
